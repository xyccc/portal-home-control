<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PortalHome" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/portal_primary</item>
        <item name="colorPrimaryVariant">@color/portal_primary_dark</item>
        <item name="colorOnPrimary">@color/portal_bg_bottom</item>
        <item name="colorSecondary">@color/portal_accent</item>
        <item name="colorSurface">@color/portal_surface</item>
        <item name="colorSurfaceVariant">@color/portal_surface_soft</item>
        <item name="colorOutline">@color/portal_outline</item>
        <item name="materialButtonStyle">@style/Widget.PortalHome.Button</item>
        <item name="android:colorBackground">@color/portal_bg_bottom</item>
        <item name="android:textColorPrimary">@color/portal_ink</item>
        <item name="android:textColorSecondary">@color/portal_ink_muted</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/portal_bg_bottom</item>
        <item name="android:statusBarColor">@color/portal_bg_bottom</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="SettingsHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/portal_primary_dark</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.PortalHome.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">28dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingLeft">22dp</item>
        <item name="android:paddingRight">22dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="SettingsField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textColor">@color/portal_ink</item>
        <item name="android:textColorHint">@color/portal_ink_muted</item>
    </style>
</resources>
