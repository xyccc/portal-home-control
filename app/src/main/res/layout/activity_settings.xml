<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView style="@style/SettingsHeader" android:text="@string/section_hue" />

        <EditText android:id="@+id/etHueBridgeIp" style="@style/SettingsField" android:hint="Bridge IP (e.g. 192.168.1.20)" android:inputType="text" />
        <EditText android:id="@+id/etHueAppKey" style="@style/SettingsField" android:hint="Hue application key" android:inputType="text" />

        <TextView style="@style/SettingsHeader" android:text="@string/section_feit" />

        <EditText android:id="@+id/etTuyaRegion" style="@style/SettingsField" android:hint="Tuya region host (e.g. openapi.tuyaus.com)" android:inputType="text" />
        <EditText android:id="@+id/etTuyaAccessId" style="@style/SettingsField" android:hint="Tuya Access ID" android:inputType="text" />
        <EditText android:id="@+id/etTuyaAccessSecret" style="@style/SettingsField" android:hint="Tuya Access Secret" android:inputType="textPassword" />
        <EditText android:id="@+id/etTuyaUid" style="@style/SettingsField" android:hint="Tuya linked-account UID" android:inputType="text" />

        <TextView style="@style/SettingsHeader" android:text="@string/section_doorbell" />

        <EditText android:id="@+id/etNestProjectId" style="@style/SettingsField" android:hint="SDM project ID (enterprises/&lt;id&gt;)" android:inputType="text" />
        <EditText android:id="@+id/etNestClientId" style="@style/SettingsField" android:hint="OAuth client ID" android:inputType="text" />
        <EditText android:id="@+id/etNestClientSecret" style="@style/SettingsField" android:hint="OAuth client secret" android:inputType="textPassword" />
        <EditText android:id="@+id/etNestRefreshToken" style="@style/SettingsField" android:hint="OAuth refresh token" android:inputType="text" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/save" />
    </LinearLayout>
</ScrollView>
