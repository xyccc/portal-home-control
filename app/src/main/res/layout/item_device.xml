<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/portal_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/portal_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingTop="10dp"
        android:paddingRight="14dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/portal_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:minHeight="54dp"
                android:scaleX="1.28"
                android:scaleY="1.28"
                app:thumbTint="@color/switch_thumb"
                app:trackTint="@color/switch_track" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderBrightness"
            android:layout_width="180dp"
            android:layout_height="38dp"
            android:layout_marginTop="-2dp"
            android:scaleY="0.78"
            android:visibility="gone"
            android:valueFrom="1"
            android:valueTo="100"
            android:stepSize="1"
            app:haloColor="@color/portal_primary_soft"
            app:haloRadius="14dp"
            app:labelBehavior="floating"
            app:thumbColor="@color/portal_primary"
            app:thumbRadius="7dp"
            app:trackColorActive="@color/portal_accent"
            app:trackColorInactive="@color/portal_outline"
            app:trackHeight="3dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
